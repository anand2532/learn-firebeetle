[Unit]
Description=Current Sensor Data Receiver
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/current-sensor-data
ExecStart=/usr/bin/python3 /home/ubuntu/current-sensor-data/ec2_data_receiver.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
